# Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://winelab:secret@localhost:5432/winelab_db?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Yandex Delivery
YANDEX_DELIVERY_TOKEN=your-yandex-delivery-token
YANDEX_DELIVERY_BASE_URL=https://b2b.taxi.yandex.net
YANDEX_DELIVERY_CALLBACK_URL=https://your-domain/api/deliveries/provider/yandex/webhook
